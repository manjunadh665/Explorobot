<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="base_length" value="0.17" />
    <xacro:property name="base_width" value="0.12" />
    <xacro:property name="base_height" value="0.05" />
    <xacro:property name="wheel_radius" value="0.03" />
    <xacro:property name="wheel_length" value="0.02" />
    <xacro:include filename="common_properties.xacro" />
    

    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height/2.0}" rpy="0 0 0" />
            <material name="green" />
        </visual>
        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height/2.0}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="1.5" x="${base_length}" y="${base_width}" z="${base_height}" 
                o_xyz="0 0 ${base_height/2.0}" o_rpy="0 0 0"/>
    </link>

    <xacro:macro name="wheel" params="prefix" >
        <link name="${prefix}_wheel">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi/2.0} 0 0"/>
                <material name="gray"/>
            </visual>
            <collision>
                <geometry>
                    <sphere radius="${wheel_radius}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </collision>
            <xacro:cylinder_inertia m="0.7" o_xyz="0 0 0" o_rpy="${pi/2.0} 0 0" r="${wheel_radius}" h="${wheel_length}" />
        </link>
    </xacro:macro>

    <xacro:wheel prefix="right_1" />
    <xacro:wheel prefix="left_1" />
    <xacro:wheel prefix="right_2" />
    <xacro:wheel prefix="left_2" />

    <link name="base_footprint" />

    <joint name="front_right_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_1_wheel"/>
        <origin xyz="${base_length/4.0} ${(base_width+wheel_length)/2.0} 0" rpy="0 0 0" />
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="front_left_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_1_wheel"/>
        <origin xyz="${base_length/4.0} ${-(base_width+wheel_length)/2.0} 0" rpy="0 0 0" />
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="back_right_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_2_wheel"/>
        <origin xyz="${-(base_length)/4.0} ${(base_width+wheel_length)/2.0} 0" rpy="0 0 0" />
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="back_left_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_2_wheel"/>
        <origin xyz="${-(base_length)/4.0} ${-(base_width+wheel_length)/2.0} 0" rpy="0 0 0" />
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 ${base_height/2.0}" rpy="0 0 0" />
    </joint>

